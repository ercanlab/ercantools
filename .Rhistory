violin_log2FC(
object = example_peaks,
title  = "log2FC: chrX vs autosomes",
ylim   = c(-2, 2)
)
# Violin todos los cromosomas
violin_log2FC_all_chr(
object = example_peaks,
title  = "log2FC por cromosoma",
ylim   = c(-2, 2)
)
